{
  "name": "pob-mcp-server",
  "version": "1.0.1",
  "description": "MCP server for Path of Building integration",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:smoke:fork": "node tests/smoke/fork-bridge.mjs && node tests/smoke/fork-mcp.mjs",
    "test:smoke:vanilla": "node tests/smoke/vanilla-bridge.mjs && node tests/smoke/vanilla-mcp.mjs",
    "test:smoke:trade": "node tests/smoke/trade-mcp.mjs",
    "test:smoke:crafting": "node tests/smoke/crafting-mcp.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bottleneck": "^2.19.5",
    "chokidar": "^4.0.3",
    "fast-xml-parser": "^5.10.1"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "@hono/node-server": "^2.0.11"
  }
}
